:3004 {
    root * /Users/danstevens/Documents/ds-electrical-website
    encode gzip

    # Defense-in-depth: block all dotfile/dotfolder access at the origin.
    # Cloudflare also blocks these with 403 at the edge, but if CF is bypassed
    # (origin IP discovery, local-network) Caddy must still refuse .git, .archive,
    # .claude, .wrangler, .pre-crop, etc. Allow .well-known for ACME/security.txt.
    @hidden {
        path */.*
        not path */.well-known/*
    }
    respond @hidden 404

    # Force-fresh on every blueprint response — no SW or browser cache survives.
    header /blueprint/* {
        Cache-Control "no-cache, no-store, must-revalidate, max-age=0"
        Pragma "no-cache"
        Expires "0"
    }

    # NOTE: solar.html and battery-storage.html are already meta-refresh stub pages
    # redirecting to /ev-chargers.html — no Caddy redirect needed. DS Electrical does not
    # offer solar/battery; the redirect captures any external links to those URLs.

    # Short URL redirects for Heritage sub-brand
    redir /heritage /heritage-installations.html 301
    redir /heritage.html /heritage-installations.html 301
    redir /listed /heritage-installations.html 301
    redir /listed-buildings /heritage-installations.html 301
    redir /period /heritage-installations.html 301
    redir /period-homes /heritage-installations.html 301
    redir /conservation /heritage-installations.html 301
    redir /grade-ii /heritage-installations.html 301

    # Proxy analytics endpoint to Node server
    handle /analytics/* {
        uri strip_prefix /analytics
        reverse_proxy localhost:3005
    }

    # Proxy booking + analytics-hit endpoints directly to the node server
    handle /api/booking {
        reverse_proxy localhost:3005
    }
    handle /hit {
        reverse_proxy localhost:3005
    }

    file_server

    # Handle www redirect
    @www host www.dselectricalsw.co.uk
    handle @www {
        root * /Users/danstevens/Documents/ds-electrical-website
        file_server
    }

    # Try files with .html extension
    try_files {path} {path}.html {path}/index.html
}
