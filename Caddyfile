:3004 {
    root * /Users/danstevens/Documents/ds-electrical-website
    encode gzip

    # Proxy analytics endpoint to Node server
    handle /analytics/* {
        uri strip_prefix /analytics
        reverse_proxy localhost:3005
    }

    file_server

    # Handle www redirect
    @www host www.dselectricalsw.co.uk
    handle @www {
        root * /Users/danstevens/Documents/ds-electrical-website
        file_server
    }

    # Try files with .html extension
    try_files {path} {path}.html {path}/index.html
}
