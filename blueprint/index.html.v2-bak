<div class="hint">Drag canvas to pan · 8 frames · 24 lanes · 150+ nodes · 2 sub-blueprints</div>

<script>
  const v = document.getElementById('viewport');
  let dragging = false, startX = 0, startY = 0, scrollX = 0, scrollY = 0;
  v.addEventListener('mousedown', e => {
    if (e.target.closest('.c, .tb-btn, a, .stat')) return;
    dragging = true; startX = e.clientX; startY = e.clientY;
    scrollX = v.scrollLeft; scrollY = v.scrollTop;
  });
  v.addEventListener('mousemove', e => {
    if (!dragging) return;
    v.scrollLeft = scrollX - (e.clientX - startX);
    v.scrollTop  = scrollY - (e.clientY - startY);
  });
  ['mouseup','mouseleave'].forEach(ev => v.addEventListener(ev, () => { dragging = false; }));
</script>
</body>
</html>
