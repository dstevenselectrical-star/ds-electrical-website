<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
<meta name="theme-color" content="#000">
<meta name="description" content="DS Electrical Operating System — every department, every system, every rule on one canvas.">
<title>DS Electrical — Operating System v2</title>
<style>
  *{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
  html,body{height:100%;background:#000;color:#e8e8e8;font-family:-apple-system,BlinkMacSystemFont,'Inter','SF Pro Text','Segoe UI',sans-serif;overflow:hidden;font-size:13px}

  /* Topbar */
  .topbar{position:fixed;top:0;left:0;right:0;height:54px;background:rgba(8,8,8,.96);backdrop-filter:blur(14px);border-bottom:1px solid rgba(255,255,255,.06);display:flex;align-items:center;justify-content:space-between;padding:0 18px;z-index:100;font-size:12px;color:#bbb}
  .tb-l{display:flex;align-items:center;gap:14px}
  .tb-l b{font-weight:700;color:#fff;font-size:13px;letter-spacing:.04em;text-transform:uppercase}
  .tb-l .div{width:1px;height:18px;background:rgba(255,255,255,.12)}
  .tb-l .v{font-family:ui-monospace,monospace;color:#7a7a7a;font-size:10.5px;letter-spacing:.06em}
  .tb-r{display:flex;align-items:center;gap:8px}
  .tb-btn{padding:6px 12px;border-radius:6px;background:rgba(255,255,255,.05);color:#ccc;border:1px solid rgba(255,255,255,.08);cursor:pointer;font-size:11.5px;font-weight:600;text-decoration:none}
  .tb-btn:hover{background:rgba(255,255,255,.1);color:#fff}
  .tb-btn.gold{background:#facc15;color:#000;border-color:#facc15}

  /* Viewport */
  .viewport{position:fixed;top:54px;left:0;right:0;bottom:0;overflow:auto;background:#0a0a0a;cursor:grab}
  .viewport:active{cursor:grabbing}
  .viewport::-webkit-scrollbar{width:10px;height:10px}
  .viewport::-webkit-scrollbar-track{background:#0a0a0a}
  .viewport::-webkit-scrollbar-thumb{background:rgba(255,255,255,.10);border-radius:6px}
  .viewport::-webkit-scrollbar-thumb:hover{background:rgba(255,255,255,.18)}

  /* Canvas */
  .canvas{position:relative;width:5200px;height:3600px;background:
    radial-gradient(circle at 1px 1px, rgba(255,255,255,.045) 1px, transparent 0);
    background-size: 24px 24px;
  }

  /* Edges layer */
  svg.edges{position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:1}
  svg.edges path{fill:none;stroke:rgba(180,180,180,.15);stroke-width:1.2}
  svg.edges path.gold{stroke:rgba(250,204,21,.55);stroke-width:1.3}
  svg.edges path.dim{stroke:rgba(180,180,180,.10)}
  svg.edges marker path{fill:rgba(180,180,180,.45);stroke:none}

  /* HERO */
  .hero{position:absolute;top:50px;left:60px;width:5080px;display:grid;grid-template-columns:1.4fr 1fr;gap:60px;z-index:5}
  .hero-l .eyebrow{font-family:ui-monospace,monospace;font-size:11px;font-weight:700;letter-spacing:.36em;color:#facc15;text-transform:uppercase;margin-bottom:16px}
  .hero-l h1{font-size:62px;font-weight:800;line-height:1.02;letter-spacing:-.022em;color:#fff;margin-bottom:14px}
  .hero-l h1 .sub{display:block;color:#facc15;font-size:.5em;font-weight:600;letter-spacing:0;margin-top:8px;font-family:ui-monospace,monospace;text-transform:uppercase;letter-spacing:.32em}
  .hero-l .desc{font-size:15px;color:#aaa;max-width:680px;line-height:1.6;margin-bottom:18px}
  .hero-l .meta{display:flex;gap:24px;font-family:ui-monospace,monospace;font-size:10.5px;color:#666;letter-spacing:.16em;text-transform:uppercase;flex-wrap:wrap}
  .hero-l .meta b{color:#fff;font-weight:700;margin-left:6px}

  .hero-r{display:grid;grid-template-columns:repeat(3,1fr);grid-template-rows:auto auto;gap:14px;align-content:start}
  .stat{padding:18px 20px;background:rgba(255,255,255,.025);border:1px solid rgba(255,255,255,.07);border-radius:8px}
  .stat .lbl{font-family:ui-monospace,monospace;font-size:9.5px;font-weight:700;letter-spacing:.22em;color:#777;text-transform:uppercase;margin-bottom:8px}
  .stat .num{font-family:ui-monospace,monospace;font-size:28px;font-weight:700;color:#fff;line-height:1;letter-spacing:-.01em}
  .stat .num.gold{color:#facc15}
  .stat .sub{font-size:11px;color:#777;margin-top:4px;letter-spacing:.04em}

  /* Phase strip */
  .phases{position:absolute;top:430px;left:60px;width:5080px;display:flex;align-items:center;gap:12px;padding:14px 26px;background:rgba(250,204,21,.04);border:1px solid rgba(250,204,21,.18);border-radius:8px;z-index:5}
  .phases .ph{font-family:ui-monospace,monospace;font-size:11px;font-weight:700;letter-spacing:.18em;color:#facc15;text-transform:uppercase;margin-right:18px}
  .phases .phase{display:flex;align-items:center;gap:10px;font-size:12px;color:#ccc;font-family:ui-monospace,monospace;letter-spacing:.08em;text-transform:uppercase}
  .phases .phase .num{display:inline-flex;align-items:center;justify-content:center;width:22px;height:22px;border-radius:50%;background:rgba(250,204,21,.12);color:#facc15;font-weight:700;font-size:11px}
  .phases .arr{color:#444;font-size:13px}

  /* Frame for each column */
  .frame{position:absolute;border:1px solid rgba(255,255,255,.10);border-radius:10px;background:rgba(255,255,255,.012);padding:16px 14px 18px;z-index:2}
  .frame .frame-head{font-family:ui-monospace,monospace;font-size:10px;font-weight:700;letter-spacing:.32em;color:#fff;text-transform:uppercase;text-align:center;padding:8px 14px;border:1px solid rgba(250,204,21,.55);border-radius:5px;background:rgba(250,204,21,.06);position:absolute;top:-15px;left:50%;transform:translateX(-50%);white-space:nowrap}
  .frame .frame-foot{font-family:ui-monospace,monospace;font-size:9.5px;color:#555;text-align:center;letter-spacing:.16em;text-transform:uppercase;margin-top:8px}

  /* Swim lane inside frame */
  .lane{margin-bottom:14px}
  .lane:last-child{margin-bottom:0}
  .lane-h{font-family:ui-monospace,monospace;font-size:9.5px;font-weight:700;letter-spacing:.22em;color:#888;text-transform:uppercase;margin-bottom:7px;padding-bottom:5px;border-bottom:1px dashed rgba(255,255,255,.08);display:flex;justify-content:space-between;align-items:baseline}
  .lane-h .ct{color:#444;font-weight:500}
  .lane-cards{display:grid;grid-template-columns:1fr 1fr;gap:6px}
  .lane-cards.one{grid-template-columns:1fr}
  .lane-cards.three{grid-template-columns:1fr 1fr 1fr}

  /* Card — small dense */
  .c{background:#141414;border:1px solid rgba(255,255,255,.10);border-radius:5px;padding:7px 9px;font-size:11px;line-height:1.36;color:#d0d0d0;transition:border-color .12s ease, transform .12s ease;cursor:default;position:relative;overflow:hidden}
  .c:hover{border-color:rgba(250,204,21,.55);transform:translateY(-1px);z-index:10}
  .c .ch{font-size:11.5px;font-weight:700;color:#fff;letter-spacing:-.005em;line-height:1.25;margin-bottom:2px}
  .c .cb{font-size:10.5px;color:#888;line-height:1.42}
  .c .pill{display:inline-block;font-family:ui-monospace,monospace;font-size:8.5px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;padding:1px 5px;border-radius:2px;margin-top:4px;margin-right:3px}
  .c .pill.gold{background:rgba(250,204,21,.14);color:#facc15}
  .c .pill.green{background:rgba(125,145,86,.16);color:#a8c47e}
  .c .pill.red{background:rgba(192,84,66,.16);color:#e08070}
  .c .pill.blue{background:rgba(120,180,220,.14);color:#9cc4e6}
  .c .pill.brown{background:rgba(180,140,90,.14);color:#c49a6c}
  .c.tall{padding:9px 10px}
  .c.tall .cb{font-size:10.5px}

  /* Sub-blueprint mini-diagrams */
  .miniblock{position:absolute;background:#0d0d0d;border:1px dashed rgba(250,204,21,.28);border-radius:8px;padding:14px 14px 12px;z-index:3}
  .miniblock .mh{font-family:ui-monospace,monospace;font-size:10px;font-weight:700;letter-spacing:.22em;color:#facc15;text-transform:uppercase;text-align:center;margin-bottom:12px}
  /* Funnel */
  .funnel-stage{height:24px;display:flex;align-items:center;justify-content:center;font-family:ui-monospace,monospace;font-size:9.5px;font-weight:700;letter-spacing:.06em;color:#000;background:rgba(250,204,21,.95);clip-path:polygon(0 0, 100% 0, 92% 100%, 8% 100%);margin-bottom:2px}
  .funnel-stage.s2{background:rgba(250,204,21,.78);clip-path:polygon(4% 0, 96% 0, 88% 100%, 12% 100%)}
  .funnel-stage.s3{background:rgba(250,204,21,.62);clip-path:polygon(8% 0, 92% 0, 84% 100%, 16% 100%)}
  .funnel-stage.s4{background:rgba(250,204,21,.48);clip-path:polygon(12% 0, 88% 0, 80% 100%, 20% 100%)}
  .funnel-stage.s5{background:rgba(250,204,21,.34);clip-path:polygon(16% 0, 84% 0, 76% 100%, 24% 100%);color:#000}
  .funnel-stage.s6{background:rgba(250,204,21,.22);clip-path:polygon(20% 0, 80% 0, 72% 100%, 28% 100%);color:#000}
  .funnel-stage.s7{background:rgba(250,204,21,.14);clip-path:polygon(24% 0, 76% 0, 68% 100%, 32% 100%);color:#000}
  /* Retention loop */
  .loop{display:grid;grid-template-columns:1fr 1fr;gap:6px}
  .loop-node{padding:6px 7px;background:#1a1a1a;border:1px solid rgba(255,255,255,.10);border-radius:4px;text-align:center;font-family:ui-monospace,monospace;font-size:9.5px;color:#ccc;letter-spacing:.06em;text-transform:uppercase;font-weight:600}

  /* Yellow accent divider — vertical between hero and frames */
  .accent{position:absolute;left:60px;right:60px;top:530px;height:1px;background:linear-gradient(90deg,transparent 0%,#facc15 6%,#facc15 94%,transparent 100%);z-index:2;opacity:.55}
  .accent-label{position:absolute;left:90px;top:516px;z-index:6;font-family:ui-monospace,monospace;font-size:10px;font-weight:700;letter-spacing:.32em;color:#facc15;text-transform:uppercase;background:#0a0a0a;padding:0 12px}

  /* Bottom phase 2 accent */
  .accent2{position:absolute;left:60px;right:60px;top:2200px;height:1px;background:linear-gradient(90deg,transparent 0%,#facc15 6%,#facc15 94%,transparent 100%);z-index:2;opacity:.45}
  .accent2-label{position:absolute;left:90px;top:2186px;z-index:6;font-family:ui-monospace,monospace;font-size:10px;font-weight:700;letter-spacing:.32em;color:#facc15;text-transform:uppercase;background:#0a0a0a;padding:0 12px}

  .hint{position:fixed;bottom:14px;left:50%;transform:translateX(-50%);font-family:ui-monospace,monospace;font-size:10px;color:#555;letter-spacing:.16em;text-transform:uppercase;z-index:50;background:rgba(0,0,0,.78);padding:6px 12px;border-radius:4px;border:1px solid rgba(255,255,255,.06);pointer-events:none}
</style>
</head>
<body>

<div class="topbar">
  <div class="tb-l">
    <b>DS Electrical · Operating System</b>
    <span class="div"></span>
    <span class="v">v2 · 2026-05-03</span>
    <span class="div"></span>
    <span class="v">8 frames · 24 lanes · 150+ nodes</span>
  </div>
  <div class="tb-r">
    <a href="/blueprints/" class="tb-btn">All blueprints</a>
    <a href="/" class="tb-btn">DS Electrical</a>
    <a href="tel:07889334849" class="tb-btn gold">07889 334849</a>
  </div>
</div>

<div class="viewport" id="viewport">
  <div class="canvas">

    <!-- HERO -->
    <div class="hero">
      <div class="hero-l">
        <div class="eyebrow">Operating System · v2 · the whole business</div>
        <h1>DS Electrical Installation SW Ltd<span class="sub">High level functionality · Phase 1 → Phase 7</span></h1>
        <div class="desc">Every department, every channel, every system, every rule on one canvas. Sales funnel + retention loop + brand pillars are sub-blueprints embedded in their parent frames. Yellow rules split major phases. Drag to pan.</div>
        <div class="meta">
          <span>Directors<b>2</b></span>
          <span>Coverage<b>Mid Somerset</b></span>
          <span>VAT<b>Registered</b></span>
          <span>Accreds<b>NAPIT · CHAS · TrustMark</b></span>
          <span>Reviews<b>5.0 Google</b></span>
          <span>Insurance<b>£2M PL</b></span>
        </div>
      </div>
      <div class="hero-r">
        <div class="stat"><div class="lbl">Frames</div><div class="num gold">8</div><div class="sub">Departments</div></div>
        <div class="stat"><div class="lbl">Swim lanes</div><div class="num">24</div><div class="sub">Sub-systems</div></div>
        <div class="stat"><div class="lbl">Nodes</div><div class="num">150+</div><div class="sub">Mapped systems</div></div>
        <div class="stat"><div class="lbl">Phase</div><div class="num">1 → 7</div><div class="sub">Lead to review</div></div>
        <div class="stat"><div class="lbl">Coverage</div><div class="num">11</div><div class="sub">Towns + villages</div></div>
        <div class="stat"><div class="lbl">Services</div><div class="num">7</div><div class="sub">Categories</div></div>
      </div>
    </div>

    <!-- PHASE STRIP -->
    <div class="phases">
      <div class="ph">Phase</div>
      <div class="phase"><span class="num">1</span><span>Lead</span></div><span class="arr">→</span>
      <div class="phase"><span class="num">2</span><span>Quote</span></div><span class="arr">→</span>
      <div class="phase"><span class="num">3</span><span>Book</span></div><span class="arr">→</span>
      <div class="phase"><span class="num">4</span><span>Survey</span></div><span class="arr">→</span>
      <div class="phase"><span class="num">5</span><span>Job</span></div><span class="arr">→</span>
      <div class="phase"><span class="num">6</span><span>Cert</span></div><span class="arr">→</span>
      <div class="phase"><span class="num">7</span><span>Invoice</span></div><span class="arr">→</span>
      <div class="phase"><span class="num">8</span><span>Review</span></div>
    </div>

    <!-- TOP YELLOW ACCENT -->
    <div class="accent"></div>
    <div class="accent-label">Phase 1 · Acquisition + Conversion</div>

    <!-- FRAMES — TOP ROW (4 frames) -->

    <!-- 1. MARKETING FRAME -->
    <div class="frame" style="top:570px;left:60px;width:760px;height:1580px">
      <div class="frame-head">Marketing Blueprint</div>

      <div class="lane">
        <div class="lane-h"><span>Channels</span><span class="ct">7 sources</span></div>
        <div class="lane-cards">
          <div class="c"><div class="ch">Google Pack</div><div class="cb">Local 3-pack on "electrician + town". 11 area pages.</div></div>
          <div class="c"><div class="ch">Organic SEO</div><div class="cb">25+ service pages, 15+ blog posts, schema markup.</div></div>
          <div class="c"><div class="ch">Checkatrade</div><div class="cb">Verified profile, 5★ reviews, lead notifications.</div></div>
          <div class="c"><div class="ch">WhatsApp share</div><div class="cb">wa.me direct from website. Mobile-first.</div></div>
          <div class="c"><div class="ch">Word of mouth</div><div class="cb">Existing customer referrals. ~40% of leads.</div></div>
          <div class="c"><div class="ch">Sister sites</div><div class="cb">wellssparky247, bathsparky247, frome, shepton.</div></div>
        </div>
      </div>

      <div class="lane">
        <div class="lane-h"><span>Service pages</span><span class="ct">25+</span></div>
        <div class="lane-cards three">
          <div class="c"><div class="ch">EICR</div></div>
          <div class="c"><div class="ch">EV charger</div></div>
          <div class="c"><div class="ch">CCTV</div></div>
          <div class="c"><div class="ch">Rewire</div></div>
          <div class="c"><div class="ch">Heritage</div></div>
          <div class="c"><div class="ch">Commercial</div></div>
          <div class="c"><div class="ch">Fire alarms</div></div>
          <div class="c"><div class="ch">Em. lighting</div></div>
          <div class="c"><div class="ch">Data/fibre</div></div>
        </div>
      </div>

      <div class="lane">
        <div class="lane-h"><span>Blog · educational</span><span class="ct">SEO</span></div>
        <div class="lane-cards">
          <div class="c"><div class="ch">EICR explained</div><div class="cb">Landlord obligations, costs, what's tested.</div></div>
          <div class="c"><div class="ch">CCTV cost guide</div><div class="cb">2026 pricing, Hikvision systems explained.</div></div>
          <div class="c"><div class="ch">3-phase upgrade</div><div class="cb">Commercial threshold + DNO process.</div></div>
          <div class="c"><div class="ch">BS5839 fire alarms</div><div class="cb">Landlord requirement + grades.</div></div>
          <div class="c"><div class="ch">Best home EV charger</div><div class="cb">Hypervolt vs Zappi vs Ohme buyer's guide.</div></div>
          <div class="c"><div class="ch">House rewire cost</div><div class="cb">Per-bedroom rough figures + access.</div></div>
        </div>
      </div>

      <div class="lane">
        <div class="lane-h"><span>Area pages</span><span class="ct">11 towns</span></div>
        <div class="lane-cards three">
          <div class="c"><div class="ch">Wells</div></div>
          <div class="c"><div class="ch">Shepton M.</div></div>
          <div class="c"><div class="ch">Bath</div></div>
          <div class="c"><div class="ch">Frome</div></div>
          <div class="c"><div class="ch">Glastonbury</div></div>
          <div class="c"><div class="ch">Street</div></div>
          <div class="c"><div class="ch">Bruton</div></div>
          <div class="c"><div class="ch">Castle Cary</div></div>
          <div class="c"><div class="ch">Radstock</div></div>
        </div>
      </div>

      <div class="lane">
        <div class="lane-h"><span>Lead capture</span><span class="ct">3 channels</span></div>
        <div class="lane-cards">
          <div class="c"><div class="ch">Contact form</div><div class="cb">→ info@ → Gmail. Same-day reply SLA.</div></div>
          <div class="c"><div class="ch">Direct phone</div><div class="cb">07889 334849 + 07983 106928.</div></div>
          <div class="c"><div class="ch">/quote/ PWA</div><div class="cb">Self-serve quote. Random QUO-NNN. PDF.</div></div>
          <div class="c"><div class="ch">WhatsApp</div><div class="cb">Photo + chat + voice notes from prospect.</div></div>
        </div>
      </div>

      <div class="lane">
        <div class="lane-h"><span>Trust signals</span><span class="ct">Conversion</span></div>
        <div class="lane-cards">
          <div class="c"><div class="ch">5.0 Google rating</div><div class="cb">11+ reviews. Embedded on every key page.</div></div>
          <div class="c"><div class="ch">Real photo gallery</div><div class="cb">100+ real client jobs. <span class="pill red">No stock</span></div></div>
          <div class="c"><div class="ch">NAPIT badge</div><div class="cb">Master accred. Above-fold on every page.</div></div>
          <div class="c"><div class="ch">CHAS / TrustMark</div><div class="cb">For commercial credibility.</div></div>
        </div>
      </div>
    </div>

    <!-- 2. SALES FRAME -->
    <div class="frame" style="top:570px;left:870px;width:760px;height:1580px">
      <div class="frame-head">Sales Blueprint</div>

      <div class="lane">
        <div class="lane-h"><span>Pipeline</span><span class="ct">7 stages</span></div>
        <div class="lane-cards">
          <div class="c"><div class="ch">Lead</div><div class="cb">Form / phone / WhatsApp / Checkatrade.</div></div>
          <div class="c"><div class="ch">Qualified</div><div class="cb">Coverage check, scope-OK, budget-fit.</div></div>
          <div class="c"><div class="ch">Quoted</div><div class="cb">Written quote &lt; 48h, valid 30 days.</div></div>
          <div class="c"><div class="ch">Booked</div><div class="cb">50% BACS deposit received.</div></div>
          <div class="c"><div class="ch">In progress</div><div class="cb">Job started, photos logged in PWA.</div></div>
          <div class="c"><div class="ch">Done</div><div class="cb">NAPIT cert + Part P notification done.</div></div>
        </div>
      </div>

      <!-- Sales funnel mini-blueprint -->
      <div class="miniblock" style="position:relative;top:0;left:0;margin:0 auto 14px;width:auto">
        <div class="mh">Pipeline funnel</div>
        <div class="funnel-stage">100% Leads</div>
        <div class="funnel-stage s2">Qualified</div>
        <div class="funnel-stage s3">Quoted</div>
        <div class="funnel-stage s4">Booked</div>
        <div class="funnel-stage s5">Job done</div>
        <div class="funnel-stage s6">Invoiced</div>
        <div class="funnel-stage s7">Review</div>
      </div>

      <div class="lane">
        <div class="lane-h"><span>Fixed-price products</span><span class="ct">£</span></div>
        <div class="lane-cards">
          <div class="c"><div class="ch">EICR 1ph</div><div class="cb">£30/circuit · 6–10 typical 3-bed.</div></div>
          <div class="c"><div class="ch">EICR 3ph</div><div class="cb">£40/circuit · commercial.</div></div>
          <div class="c"><div class="ch">Fuse board check</div><div class="cb">£99 fixed · credited on upgrade.</div></div>
          <div class="c"><div class="ch">EV charger</div><div class="cb">£495 fixed · Type A RCBO · OZEV.</div></div>
          <div class="c"><div class="ch">Rewire</div><div class="cb">From £3,500 · per-circuit pricing.</div></div>
          <div class="c"><div class="ch">Heritage</div><div class="cb">From £15K · concealed wiring.</div></div>
        </div>
      </div>

      <div class="lane">
        <div class="lane-h"><span>Quote process</span><span class="ct">≤ 48h</span></div>
        <div class="lane-cards">
          <div class="c"><div class="ch">Free site survey</div><div class="cb">Director attends, scope confirmed.</div></div>
          <div class="c"><div class="ch">Random QUO-NNN</div><div class="cb">QUO-100 to QUO-999, never sequential.</div></div>
          <div class="c"><div class="ch">Written quote PDF</div><div class="cb">Net + VAT 20% + total · 30-day valid.</div></div>
          <div class="c"><div class="ch">No "while we're here"</div><div class="cb">Price you agree = price you pay.</div></div>
        </div>
      </div>

      <div class="lane">
        <div class="lane-h"><span>Terms</span><span class="ct">BACS only</span></div>
        <div class="lane-cards">
          <div class="c"><div class="ch">50% deposit</div><div class="cb">On booking · funds materials.</div></div>
          <div class="c"><div class="ch">50% completion</div><div class="cb">On test + cert handover.</div></div>
