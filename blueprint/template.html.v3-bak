<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
<meta name="theme-color" content="#000">
<title>Blueprint — DS Operating System</title>
<meta name="description" content="DS business blueprint — every department on one canvas.">
<style>
  *{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
  html,body{height:100%;background:#000;color:#e8e8e8;font-family:-apple-system,BlinkMacSystemFont,'Inter','SF Pro Text','Segoe UI',sans-serif;overflow:hidden;font-size:13px}

  .topbar{position:fixed;top:0;left:0;right:0;height:54px;background:rgba(8,8,8,.96);backdrop-filter:blur(14px);border-bottom:1px solid rgba(255,255,255,.06);display:flex;align-items:center;justify-content:space-between;padding:0 18px;z-index:100;font-size:12px;color:#bbb}
  .tb-l{display:flex;align-items:center;gap:14px;min-width:0;flex:1}
  .tb-l b{font-weight:700;color:#fff;font-size:13px;letter-spacing:.04em;text-transform:uppercase;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .tb-l .div{width:1px;height:18px;background:rgba(255,255,255,.12)}
  .tb-l .v{font-family:ui-monospace,monospace;color:#7a7a7a;font-size:10.5px;letter-spacing:.06em;white-space:nowrap}
  .tb-r{display:flex;align-items:center;gap:8px}
  .tb-btn{padding:6px 12px;border-radius:6px;background:rgba(255,255,255,.05);color:#ccc;border:1px solid rgba(255,255,255,.08);cursor:pointer;font-size:11.5px;font-weight:600;text-decoration:none;white-space:nowrap}
  .tb-btn:hover{background:rgba(255,255,255,.1);color:#fff}
  .tb-btn.gold{background:#facc15;color:#000;border-color:#facc15}

  .viewport{position:fixed;top:54px;left:0;right:0;bottom:0;overflow:auto;background:#0a0a0a;cursor:grab}
  .viewport:active{cursor:grabbing}
  .viewport::-webkit-scrollbar{width:10px;height:10px}
  .viewport::-webkit-scrollbar-track{background:#0a0a0a}
  .viewport::-webkit-scrollbar-thumb{background:rgba(255,255,255,.10);border-radius:6px}
  .viewport::-webkit-scrollbar-thumb:hover{background:rgba(255,255,255,.18)}

  .canvas-wrap{transform-origin:0 0;transition:transform .15s ease-out}
  .canvas{position:relative;width:5400px;height:3800px;background:radial-gradient(circle at 1px 1px, rgba(255,255,255,.045) 1px, transparent 0);background-size:24px 24px}

  svg.edges{position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none;z-index:1}
  svg.edges path{fill:none;stroke:rgba(180,180,180,.16);stroke-width:1.2}
  svg.edges path.gold{stroke:rgba(250,204,21,.55);stroke-width:1.4}
  svg.edges path.dim{stroke:rgba(180,180,180,.10)}

  .icon-defs{position:absolute;width:0;height:0;overflow:hidden}
  .ic{display:inline-block;width:11px;height:11px;vertical-align:-1px;color:currentColor;flex-shrink:0}

  .hero{position:absolute;top:50px;left:60px;width:5280px;display:grid;grid-template-columns:1.4fr 1fr;gap:60px;z-index:5}
  .hero-l .eyebrow{font-family:ui-monospace,monospace;font-size:11px;font-weight:700;letter-spacing:.36em;color:#facc15;text-transform:uppercase;margin-bottom:16px}
  .hero-l h1{font-size:62px;font-weight:800;line-height:1.02;letter-spacing:-.022em;color:#fff;margin-bottom:14px}
  .hero-l h1 .sub{display:block;color:#facc15;font-size:.5em;font-weight:600;margin-top:8px;font-family:ui-monospace,monospace;text-transform:uppercase;letter-spacing:.32em}
  .hero-l .desc{font-size:15px;color:#aaa;max-width:680px;line-height:1.6;margin-bottom:18px}
  .hero-l .meta{display:flex;gap:24px;font-family:ui-monospace,monospace;font-size:10.5px;color:#666;letter-spacing:.16em;text-transform:uppercase;flex-wrap:wrap}
  .hero-l .meta b{color:#fff;font-weight:700;margin-left:6px}

  .hero-r{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;align-content:start}
  .stat{padding:18px 20px;background:rgba(255,255,255,.025);border:1px solid rgba(255,255,255,.07);border-radius:8px;position:relative;overflow:hidden}
  .stat::after{content:'';position:absolute;left:0;top:0;width:3px;height:100%;background:#facc15;opacity:.4}
  .stat .lbl{font-family:ui-monospace,monospace;font-size:9.5px;font-weight:700;letter-spacing:.22em;color:#888;text-transform:uppercase;margin-bottom:8px}
  .stat .num{font-family:ui-monospace,monospace;font-size:30px;font-weight:700;color:#fff;line-height:1;letter-spacing:-.01em}
  .stat .num.gold{color:#facc15}
  .stat .sub{font-size:11px;color:#888;margin-top:4px}

  .phases{position:absolute;top:430px;left:60px;width:5280px;display:flex;align-items:center;gap:12px;padding:14px 26px;background:rgba(250,204,21,.04);border:1px solid rgba(250,204,21,.18);border-radius:8px;z-index:5}
  .phases .ph{font-family:ui-monospace,monospace;font-size:11px;font-weight:700;letter-spacing:.18em;color:#facc15;text-transform:uppercase;margin-right:18px}
  .phases .phase{display:flex;align-items:center;gap:10px;font-size:12px;color:#ccc;font-family:ui-monospace,monospace;letter-spacing:.08em;text-transform:uppercase}
  .phases .phase .num{display:inline-flex;align-items:center;justify-content:center;width:22px;height:22px;border-radius:50%;background:rgba(250,204,21,.12);color:#facc15;font-weight:700;font-size:11px}
  .phases .arr{color:#444;font-size:13px}

  .frame{position:absolute;border:1px solid rgba(255,255,255,.10);border-radius:10px;background:rgba(255,255,255,.012);padding:18px 14px 18px;z-index:2}
  .frame .frame-head{font-family:ui-monospace,monospace;font-size:10px;font-weight:700;letter-spacing:.32em;color:#fff;text-transform:uppercase;text-align:center;padding:8px 16px;border:1px solid rgba(250,204,21,.55);border-radius:5px;background:rgba(250,204,21,.06);position:absolute;top:-15px;left:50%;transform:translateX(-50%);white-space:nowrap;display:inline-flex;align-items:center;gap:8px}
  .frame .frame-head .fnum{font-family:ui-monospace,monospace;font-size:9px;color:#facc15;background:rgba(250,204,21,.18);padding:1px 5px;border-radius:2px}
  .frame.phase1 .frame-head{border-color:rgba(120,180,220,.6);background:rgba(120,180,220,.08);color:#cfe5f6}
  .frame.phase1 .frame-head .fnum{color:#9cc4e6;background:rgba(120,180,220,.18)}

  .lane{margin-bottom:14px}
  .lane:last-child{margin-bottom:0}
  .lane-h{font-family:ui-monospace,monospace;font-size:9.5px;font-weight:700;letter-spacing:.22em;color:#bbb;text-transform:uppercase;margin-bottom:7px;padding:5px 6px 5px 8px;border-radius:3px;display:flex;justify-content:space-between;align-items:center;background:rgba(255,255,255,.025);border-left:2px solid #facc15}
  .lane-h.b{border-left-color:#9cc4e6}
  .lane-h.g{border-left-color:#a8c47e}
  .lane-h.r{border-left-color:#e08070}
  .lane-h .ll{display:flex;align-items:center;gap:6px}
  .lane-h .ll .ic{color:#facc15;opacity:.85}
  .lane-h.b .ll .ic{color:#9cc4e6}
  .lane-h.g .ll .ic{color:#a8c47e}
  .lane-h.r .ll .ic{color:#e08070}
  .lane-h .ct{color:#666;font-weight:500;font-size:9px}
  .lane-cards{display:grid;grid-template-columns:1fr 1fr;gap:6px}
  .lane-cards.one{grid-template-columns:1fr}
  .lane-cards.three{grid-template-columns:1fr 1fr 1fr}

  .c{background:#141414;border:1px solid rgba(255,255,255,.10);border-radius:5px;padding:7px 9px;font-size:11px;line-height:1.36;color:#d0d0d0;transition:border-color .12s ease, transform .12s ease;cursor:default;position:relative;overflow:hidden}
  .c:hover{border-color:rgba(250,204,21,.55);transform:translateY(-1px);z-index:10}
  .c .ch{font-size:11.5px;font-weight:700;color:#fff;letter-spacing:-.005em;line-height:1.25;margin-bottom:2px;display:flex;justify-content:space-between;align-items:baseline;gap:6px}
  .c .ch .kpi{font-family:ui-monospace,monospace;font-size:10px;color:#facc15;font-weight:600;letter-spacing:0;flex-shrink:0;white-space:nowrap}
  .c .cb{font-size:10.5px;color:#8c8c8c;line-height:1.4}
  .c .pill{display:inline-block;font-family:ui-monospace,monospace;font-size:8.5px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;padding:1px 5px;border-radius:2px;margin-top:4px;margin-right:3px}
  .c .pill.gold{background:rgba(250,204,21,.14);color:#facc15}
  .c .pill.green{background:rgba(125,145,86,.16);color:#a8c47e}
  .c .pill.red{background:rgba(192,84,66,.16);color:#e08070}
  .c .pill.blue{background:rgba(120,180,220,.14);color:#9cc4e6}

  .miniblock{background:#0d0d0d;border:1px dashed rgba(250,204,21,.32);border-radius:8px;padding:12px 12px 10px;margin-bottom:14px;position:relative}
  .miniblock .mh{font-family:ui-monospace,monospace;font-size:9.5px;font-weight:700;letter-spacing:.22em;color:#facc15;text-transform:uppercase;text-align:center;margin-bottom:11px;display:flex;align-items:center;justify-content:center;gap:6px}
  .funnel-stage{height:22px;display:flex;align-items:center;justify-content:space-between;padding:0 10px;font-family:ui-monospace,monospace;font-size:9.5px;font-weight:700;letter-spacing:.06em;color:#000;background:rgba(250,204,21,.95);clip-path:polygon(0 0, 100% 0, 92% 100%, 8% 100%);margin-bottom:2px}
  .funnel-stage.s2{background:rgba(250,204,21,.78);clip-path:polygon(4% 0, 96% 0, 88% 100%, 12% 100%)}
  .funnel-stage.s3{background:rgba(250,204,21,.62);clip-path:polygon(8% 0, 92% 0, 84% 100%, 16% 100%)}
  .funnel-stage.s4{background:rgba(250,204,21,.48);clip-path:polygon(12% 0, 88% 0, 80% 100%, 20% 100%)}
  .funnel-stage.s5{background:rgba(250,204,21,.34);clip-path:polygon(16% 0, 84% 0, 76% 100%, 24% 100%)}
  .funnel-stage.s6{background:rgba(250,204,21,.22);clip-path:polygon(20% 0, 80% 0, 72% 100%, 28% 100%)}
  .funnel-stage.s7{background:rgba(250,204,21,.14);clip-path:polygon(24% 0, 76% 0, 68% 100%, 32% 100%)}
  .funnel-stage .pct{font-size:8.5px;font-weight:600;opacity:.75}

  .pareto{display:flex;flex-direction:column;gap:5px}
  .par-row{display:grid;grid-template-columns:80px 1fr 38px;gap:8px;align-items:center}
  .par-row .pl{font-family:ui-monospace,monospace;font-size:9.5px;color:#ccc;letter-spacing:.04em;text-transform:uppercase;font-weight:600}
  .par-row .pb{height:14px;background:rgba(250,204,21,.85);border-radius:2px;position:relative}
  .par-row.t2 .pb{background:rgba(250,204,21,.58)}
  .par-row.t3 .pb{background:rgba(250,204,21,.34)}
  .par-row.t4 .pb{background:rgba(180,180,180,.22)}
  .par-row .pn{font-family:ui-monospace,monospace;font-size:10px;color:#facc15;font-weight:700;text-align:right}

  .stack{display:flex;flex-direction:column;gap:3px}
  .stack-row{padding:8px 10px;border-radius:4px;font-family:ui-monospace,monospace;font-size:9.5px;font-weight:700;letter-spacing:.08em;text-transform:uppercase;display:flex;justify-content:space-between;align-items:center;border:1px solid rgba(255,255,255,.10);background:rgba(255,255,255,.04);color:#ccc}
  .stack-row.s1{background:rgba(120,180,220,.14);color:#9cc4e6;border-color:rgba(120,180,220,.25)}
  .stack-row.s2{background:rgba(168,196,126,.13);color:#a8c47e;border-color:rgba(168,196,126,.25)}
  .stack-row.s3{background:rgba(250,204,21,.12);color:#facc15;border-color:rgba(250,204,21,.25)}
  .stack-row .sl{font-size:8.5px;color:#666;font-weight:500}

  .accent{position:absolute;left:60px;width:5280px;height:1px;background:linear-gradient(90deg,transparent 0%,#facc15 6%,#facc15 94%,transparent 100%);z-index:2;opacity:.55}
  .accent-label{position:absolute;z-index:6;font-family:ui-monospace,monospace;font-size:10px;font-weight:700;letter-spacing:.32em;color:#facc15;text-transform:uppercase;background:#0a0a0a;padding:0 12px}

  .zoom{position:fixed;right:14px;bottom:14px;z-index:60;display:flex;flex-direction:column;gap:4px;background:rgba(8,8,8,.92);border:1px solid rgba(255,255,255,.08);border-radius:8px;padding:6px;backdrop-filter:blur(12px)}
  .zoom button{width:34px;height:34px;border-radius:5px;background:rgba(255,255,255,.04);color:#ccc;border:1px solid rgba(255,255,255,.06);cursor:pointer;font-size:14px;font-weight:700;display:flex;align-items:center;justify-content:center;transition:.12s}
  .zoom button:hover{background:rgba(250,204,21,.15);color:#facc15;border-color:rgba(250,204,21,.4)}
  .zoom .lvl{font-family:ui-monospace,monospace;font-size:9.5px;color:#888;text-align:center;letter-spacing:.06em;padding:2px 0;font-weight:600}

  .minimap{position:fixed;left:14px;bottom:14px;z-index:60;width:220px;height:160px;background:rgba(8,8,8,.92);border:1px solid rgba(255,255,255,.08);border-radius:8px;padding:8px;backdrop-filter:blur(12px)}
  .minimap .mm-h{font-family:ui-monospace,monospace;font-size:8.5px;color:#888;letter-spacing:.16em;text-transform:uppercase;font-weight:700;margin-bottom:4px}
  .minimap .mm-c{position:relative;width:100%;height:128px;background:#0d0d0d;border-radius:4px;overflow:hidden}
  .minimap .mm-c .mm-frame{position:absolute;background:rgba(250,204,21,.14);border:1px solid rgba(250,204,21,.4);border-radius:1.5px}
  .minimap .mm-c .mm-frame.p1{background:rgba(120,180,220,.10);border-color:rgba(120,180,220,.35)}
  .minimap .mm-c .mm-vp{position:absolute;border:1.5px solid #facc15;background:rgba(250,204,21,.14);border-radius:2px;cursor:pointer;pointer-events:auto}

  .err{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);background:#1a1a1a;border:1px solid rgba(192,84,66,.4);border-radius:8px;padding:30px 40px;color:#e08070;font-family:ui-monospace,monospace;font-size:13px;text-align:center;z-index:200}
  .err .h{font-size:18px;font-weight:700;color:#fff;margin-bottom:10px}
  .err a{color:#facc15;border-bottom:1px dotted #facc15;text-decoration:none}
</style>
</head>
<body>

<svg class="icon-defs" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <symbol id="i-megaphone" viewBox="0 0 16 16"><path fill="currentColor" d="M3 5L11 2v12L3 11H2a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1h1zm10 1.5a1.5 1.5 0 0 1 0 3z"/></symbol>
    <symbol id="i-target" viewBox="0 0 16 16"><circle cx="8" cy="8" r="6" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="8" cy="8" r="3" fill="none" stroke="currentColor" stroke-width="1.5"/><circle cx="8" cy="8" r="1" fill="currentColor"/></symbol>
    <symbol id="i-funnel" viewBox="0 0 16 16"><path fill="currentColor" d="M2 3h12l-4 5v5l-4-2V8z"/></symbol>
    <symbol id="i-pound" viewBox="0 0 16 16"><path fill="currentColor" d="M5 2c2 0 3 1 3 3v2H5v1h3v2c0 1-.5 2-1 2h6v2H4v-2c1 0 1-1 1-2V8H4V7h1V5c0-2 0-3 0-3z"/></symbol>
    <symbol id="i-doc" viewBox="0 0 16 16"><path fill="currentColor" d="M3 1h7l3 3v11H3zm6 0v3h3M5 7h6M5 9h6M5 11h4"/></symbol>
    <symbol id="i-check" viewBox="0 0 16 16"><circle cx="8" cy="8" r="7" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M5 8l2 2 4-4" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></symbol>
    <symbol id="i-shield" viewBox="0 0 16 16"><path fill="currentColor" d="M8 1L2 3v5c0 4 6 7 6 7s6-3 6-7V3z"/></symbol>
    <symbol id="i-tools" viewBox="0 0 16 16"><path fill="currentColor" d="M3 11l5-5 1 1-5 5zm6-9l3 3-2 2-3-3zm-7 9l1 3 3 1L4 13z"/></symbol>
    <symbol id="i-pin" viewBox="0 0 16 16"><path fill="currentColor" d="M8 1a4 4 0 0 0-4 4c0 3 4 9 4 9s4-6 4-9a4 4 0 0 0-4-4zm0 5.5a1.5 1.5 0 1 1 0-3 1.5 1.5 0 0 1 0 3z"/></symbol>
    <symbol id="i-clock" viewBox="0 0 16 16"><circle cx="8" cy="8" r="7" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M8 4v4l3 2" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></symbol>
    <symbol id="i-phone" viewBox="0 0 16 16"><path fill="currentColor" d="M3 1l2 1 1 3-2 1c1 3 3 5 6 6l1-2 3 1 1 2c0 1-1 2-2 2C7 15 1 9 1 3c0-1 1-2 2-2z"/></symbol>
    <symbol id="i-truck" viewBox="0 0 16 16"><path fill="currentColor" d="M1 4h8v6h2l3-3v3h1v2h-2a2 2 0 0 1-4 0H4a2 2 0 0 1-4 0V5z"/></symbol>
    <symbol id="i-stack" viewBox="0 0 16 16"><path fill="currentColor" d="M8 1L1 5l7 4 7-4zm-7 6l7 4 7-4M1 11l7 4 7-4"/></symbol>
    <symbol id="i-bolt" viewBox="0 0 16 16"><path fill="currentColor" d="M9 1L3 9h4l-1 6 7-9H8z"/></symbol>
    <symbol id="i-link" viewBox="0 0 16 16"><path fill="none" stroke="currentColor" stroke-width="1.6" d="M6 10l4-4M5 7l-2 2a2 2 0 0 0 3 3l2-2M11 9l2-2a2 2 0 0 0-3-3l-2 2"/></symbol>
    <symbol id="i-palette" viewBox="0 0 16 16"><path fill="currentColor" d="M8 2a6 6 0 0 0 0 12c1 0 2-1 1-2-1-1 0-2 2-2h2a3 3 0 0 0 3-3c0-3-3-5-8-5zM4 7a1 1 0 1 1 0 2 1 1 0 0 1 0-2zm3-3a1 1 0 1 1 0 2 1 1 0 0 1 0-2zm5 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2z"/></symbol>
    <symbol id="i-mic" viewBox="0 0 16 16"><rect x="6" y="1" width="4" height="9" rx="2" fill="currentColor"/><path d="M3 8a5 5 0 0 0 10 0M8 13v2" fill="none" stroke="currentColor" stroke-width="1.5"/></symbol>
    <symbol id="i-people" viewBox="0 0 16 16"><circle cx="5" cy="5" r="2.5" fill="currentColor"/><circle cx="11" cy="6" r="2" fill="currentColor"/><path fill="currentColor" d="M1 14c0-3 2-5 4-5s4 2 4 5zM9 14c0-2 1-4 3-4s3 2 3 4z"/></symbol>
    <symbol id="i-plug" viewBox="0 0 16 16"><path fill="currentColor" d="M5 1v3h6V1zm-1 4h8v3a4 4 0 0 1-3 4v3H7v-3a4 4 0 0 1-3-4z"/></symbol>
    <symbol id="i-camera" viewBox="0 0 16 16"><path fill="currentColor" d="M5 3l1-2h4l1 2h3a1 1 0 0 1 1 1v9a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1zm3 9a4 4 0 1 0 0-8 4 4 0 0 0 0 8z"/></symbol>
    <symbol id="i-bag" viewBox="0 0 16 16"><path fill="currentColor" d="M5 3a3 3 0 0 1 6 0v1h2l1 11H2L3 4h2zm1 0v1h4V3a2 2 0 0 0-4 0z"/></symbol>
    <symbol id="i-cart" viewBox="0 0 16 16"><path fill="currentColor" d="M1 2h2l2 9h8l2-7H5"/></symbol>
    <symbol id="i-globe" viewBox="0 0 16 16"><circle cx="8" cy="8" r="7" fill="none" stroke="currentColor" stroke-width="1.5"/><path d="M1 8h14M8 1c2 2 3 5 3 7s-1 5-3 7c-2-2-3-5-3-7s1-5 3-7" fill="none" stroke="currentColor" stroke-width="1.5"/></symbol>
    <symbol id="i-fish" viewBox="0 0 16 16"><path fill="currentColor" d="M2 8c1-3 4-5 8-5l4 2-2 3 2 3-4 2c-4 0-7-2-8-5zm10 0a1 1 0 1 1 0-2 1 1 0 0 1 0 2z"/></symbol>
  </defs>
</svg>

<div class="topbar">
  <div class="tb-l">
    <b id="tbName">Loading…</b>
    <span class="div"></span>
    <span class="v" id="tbVer">v1</span>
    <span class="div"></span>
    <span class="v" id="tbCount"></span>
  </div>
  <div class="tb-r">
    <a href="/blueprints/" class="tb-btn">All blueprints</a>
    <a href="/" class="tb-btn">DS Electrical</a>
    <a href="tel:07889334849" class="tb-btn gold">07889 334849</a>
  </div>
</div>

<div class="viewport" id="viewport">
  <div class="canvas-wrap" id="canvasWrap">
    <div class="canvas" id="canvas"></div>
  </div>
</div>

<div class="zoom">
  <button id="zIn" title="Zoom in">+</button>
  <div class="lvl" id="zLevel">100%</div>
  <button id="zOut" title="Zoom out">−</button>
  <button id="zFit" title="Fit width" style="font-size:10px">FIT</button>
  <button id="zReset" title="Reset 100%" style="font-size:10px">1:1</button>
</div>

<div class="minimap">
  <div class="mm-h" id="mmHeader">Minimap</div>
  <div class="mm-c" id="mmCanvas">
    <div class="mm-vp" id="mmVp"></div>
  </div>
</div>

<script>
(() => {
  // ===== Helpers (no innerHTML — createElement + textContent for safety) =====
  function el(tag, attrs, children){
    const e = document.createElement(tag);
    if (attrs) for (const k in attrs){
      if (k === 'style') Object.assign(e.style, attrs[k]);
      else if (k === 'cls') e.className = attrs[k];
      else if (k === 'text') e.textContent = attrs[k];
      else if (k.startsWith('data-')) e.setAttribute(k, attrs[k]);
      else e.setAttribute(k, attrs[k]);
    }
    if (children) (Array.isArray(children) ? children : [children]).forEach(c => {
      if (c == null) return;
      if (typeof c === 'string') e.appendChild(document.createTextNode(c));
      else e.appendChild(c);
    });
    return e;
  }
  // Inline icon ref: <svg class="ic"><use href="#i-x"/></svg>
  function icon(name){
    const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
    svg.setAttribute('class', 'ic');
    const use = document.createElementNS('http://www.w3.org/2000/svg', 'use');
    use.setAttributeNS('http://www.w3.org/1999/xlink', 'href', '#' + name);
    use.setAttribute('href', '#' + name);
    svg.appendChild(use);
    return svg;
  }

  // ===== Renderers per JSON shape =====
  function renderHero(data){
    const wrap = el('div', {cls:'hero'});
    const left = el('div', {cls:'hero-l'});
    left.appendChild(el('div', {cls:'eyebrow', text: data.eyebrow || 'Operating System · the whole business'}));
    const h1 = el('h1', null, [data.name]);
    if (data.tagline) {
      const sub = el('span', {cls:'sub', text: data.tagline});
      h1.appendChild(sub);
    }
    left.appendChild(h1);
    if (data.description) left.appendChild(el('p', {cls:'desc', text: data.description}));
    if (data.meta && data.meta.length){
      const meta = el('div', {cls:'meta'});
      data.meta.forEach(([k,v]) => {
        const span = el('span', null, [k]);
        const b = el('b', {text: v});
        span.appendChild(b);
        meta.appendChild(span);
      });
      left.appendChild(meta);
    }
    wrap.appendChild(left);

    const right = el('div', {cls:'hero-r'});
    (data.stats || []).forEach(s => {
      const stat = el('div', {cls:'stat'});
      stat.appendChild(el('div', {cls:'lbl', text: s.label}));
      stat.appendChild(el('div', {cls:'num' + (s.gold ? ' gold' : ''), text: s.num}));
      if (s.sub) stat.appendChild(el('div', {cls:'sub', text: s.sub}));
      right.appendChild(stat);
    });
    wrap.appendChild(right);
    return wrap;
  }

  function renderPhases(phases){
    const wrap = el('div', {cls:'phases'});
    wrap.appendChild(el('div', {cls:'ph', text:'Phase'}));
    phases.forEach((p, i) => {
      if (i > 0) wrap.appendChild(el('span', {cls:'arr', text:'→'}));
      const ph = el('div', {cls:'phase'});
      ph.appendChild(el('span', {cls:'num', text: String(i+1)}));
      ph.appendChild(el('span', {text: p}));
      wrap.appendChild(ph);
    });
    return wrap;
  }

  function renderCard(c){
    const card = el('div', {cls:'c'});
    const ch = el('div', {cls:'ch'});
    const titleSpan = el('span', null, [c.title]);
    if (c.titlePill) {
      const pill = el('span', {cls:'pill ' + (c.titlePillColor || 'gold'), text: c.titlePill});
      titleSpan.appendChild(document.createTextNode(' '));
      titleSpan.appendChild(pill);
    }
    ch.appendChild(titleSpan);
    if (c.kpi) ch.appendChild(el('span', {cls:'kpi', text: c.kpi}));
    card.appendChild(ch);
    if (c.body){
      const cb = el('div', {cls:'cb', text: c.body});
      card.appendChild(cb);
    }
    if (c.pills && c.pills.length){
      const cb = el('div', {cls:'cb'});
      c.pills.forEach(p => cb.appendChild(el('span', {cls:'pill ' + (p.color||'gold'), text: p.text})));
      card.appendChild(cb);
    }
    return card;
  }

  function renderLane(lane){
    const wrap = el('div', {cls:'lane'});
    const lh = el('div', {cls:'lane-h' + (lane.color ? ' ' + lane.color : '')});
    const ll = el('div', {cls:'ll'});
    if (lane.icon) ll.appendChild(icon(lane.icon));
    ll.appendChild(document.createTextNode(' ' + lane.header));
    lh.appendChild(ll);
    if (lane.count) lh.appendChild(el('span', {cls:'ct', text: lane.count}));
    wrap.appendChild(lh);
    const grid = el('div', {cls:'lane-cards' + (lane.cols === 3 ? ' three' : lane.cols === 1 ? ' one' : '')});
    (lane.cards || []).forEach(c => grid.appendChild(renderCard(c)));
    wrap.appendChild(grid);
    return wrap;
  }

  function renderMini(m){
    const wrap = el('div', {cls:'miniblock'});
    const mh = el('div', {cls:'mh'});
    if (m.icon) mh.appendChild(icon(m.icon));
    mh.appendChild(document.createTextNode(' ' + m.title));
    wrap.appendChild(mh);
    if (m.type === 'funnel'){
      m.stages.forEach((s, i) => {
        const stage = el('div', {cls:'funnel-stage' + (i ? ' s' + (i+1) : '')});
        stage.appendChild(el('span', {text: s.label}));
        if (s.pct != null) stage.appendChild(el('span', {cls:'pct', text: s.pct}));
        wrap.appendChild(stage);
      });
    } else if (m.type === 'pareto'){
      const par = el('div', {cls:'pareto'});
      m.rows.forEach((r, i) => {
        const tier = i === 0 ? '' : i <= 1 ? ' t2' : i <= 2 ? ' t3' : ' t4';
        const row = el('div', {cls:'par-row' + tier});
        row.appendChild(el('div', {cls:'pl', text: r.label}));
        const bar = el('div', {cls:'pb', style:{width: r.width || '50%'}});
        row.appendChild(bar);
        row.appendChild(el('div', {cls:'pn', text: r.value}));
        par.appendChild(row);
      });
      wrap.appendChild(par);
    } else if (m.type === 'stack'){
      const st = el('div', {cls:'stack'});
      m.rows.forEach((r, i) => {
        const tier = i < 3 ? ' s' + (i+1) : '';
        const row = el('div', {cls:'stack-row' + tier});
        row.appendChild(el('span', {text: r.label}));
        if (r.layer) row.appendChild(el('span', {cls:'sl', text: r.layer}));
        st.appendChild(row);
      });
      wrap.appendChild(st);
    }
    return wrap;
  }

  function renderFrame(f, idx){
    const wrap = el('div', {cls:'frame ' + (f.phase === 1 ? 'phase1' : 'phase2'),
                            style:{top: f.top + 'px', left: f.left + 'px',
                                   width: (f.width || 780) + 'px', height: (f.height || 1320) + 'px'}});
    const head = el('div', {cls:'frame-head'});
    head.appendChild(el('span', {cls:'fnum', text: String(idx+1).padStart(2,'0')}));
    head.appendChild(document.createTextNode(' ' + f.title));
    wrap.appendChild(head);
    (f.lanes || []).forEach(lane => {
      wrap.appendChild(renderLane(lane));
      // Insert mini-blueprint right after the lane it's anchored to
      if (lane.miniAfter && f.minis){
        const m = f.minis.find(mi => mi.id === lane.miniAfter);
        if (m) wrap.appendChild(renderMini(m));
      }
    });
    // Append any minis that weren't anchored
    if (f.minis){
      f.minis.filter(m => !m.anchored).forEach(m => {
        if (!(f.lanes || []).some(l => l.miniAfter === m.id)){
          wrap.appendChild(renderMini(m));
        }
      });
    }
    return wrap;
  }

  function renderEdges(edges){
    const SVG_NS = 'http://www.w3.org/2000/svg';
    const svg = document.createElementNS(SVG_NS, 'svg');
    svg.setAttribute('class', 'edges');
    svg.setAttribute('viewBox', '0 0 5400 3800');
    svg.setAttribute('preserveAspectRatio', 'none');
    const defs = document.createElementNS(SVG_NS, 'defs');
    ['arr','arr-gold'].forEach(id => {
      const marker = document.createElementNS(SVG_NS, 'marker');
      marker.setAttribute('id', id);
      marker.setAttribute('viewBox', '0 0 10 10');
      marker.setAttribute('refX', '8');
      marker.setAttribute('refY', '5');
      marker.setAttribute('markerWidth', '6');
      marker.setAttribute('markerHeight', '6');
      marker.setAttribute('orient', 'auto');
      const path = document.createElementNS(SVG_NS, 'path');
      path.setAttribute('d', 'M 0 0 L 10 5 L 0 10 z');
      path.setAttribute('fill', id === 'arr-gold' ? 'rgba(250,204,21,.65)' : 'rgba(180,180,180,.5)');
      marker.appendChild(path);
      defs.appendChild(marker);
    });
    svg.appendChild(defs);
    (edges || []).forEach(e => {
      const path = document.createElementNS(SVG_NS, 'path');
      path.setAttribute('d', e.d);
      if (e.cls) path.setAttribute('class', e.cls);
      if (e.arrow) path.setAttribute('marker-end', 'url(#' + (e.arrow === 'gold' ? 'arr-gold' : 'arr') + ')');
      svg.appendChild(path);
    });
    return svg;
  }

  function renderAccents(accents){
    const frag = document.createDocumentFragment();
    (accents || []).forEach(a => {
      const line = el('div', {cls:'accent', style:{top: a.top + 'px'}});
      const label = el('div', {cls:'accent-label', style:{top: (a.top - 14) + 'px', left: '90px'}, text: a.label});
      frag.appendChild(line);
      frag.appendChild(label);
    });
    return frag;
  }

  function renderMinimap(frames){
    const mm = document.getElementById('mmCanvas');
    const CW = 5400, CH = 3800;
    frames.forEach(f => {
      const div = el('div', {cls:'mm-frame' + (f.phase === 1 ? ' p1' : '')});
      div.style.left = ((f.left / CW) * 100) + '%';
      div.style.top = ((f.top / CH) * 100) + '%';
      div.style.width = ((f.width || 780) / CW * 100) + '%';
      div.style.height = ((f.height || 1320) / CH * 100) + '%';
      mm.insertBefore(div, document.getElementById('mmVp'));
    });
  }

  function showError(title, body){
    const e = el('div', {cls:'err'});
    e.appendChild(el('div', {cls:'h', text: title}));
    e.appendChild(el('div', {text: body}));
    e.appendChild(el('div', {style:{marginTop:'18px'}}));
    const link = el('a', {href:'/blueprints/', text:'← back to all blueprints'});
    e.appendChild(link);
    document.body.appendChild(e);
  }

  // ===== Boot =====
  const params = new URLSearchParams(location.search);
  const biz = params.get('biz') || 'ds-electrical';

  fetch('/blueprint/data/' + biz + '.json')
    .then(r => { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
    .then(data => {
      // Topbar
      document.getElementById('tbName').textContent = data.topbarTitle || (data.name + ' · Operating System');
      document.getElementById('tbVer').textContent = (data.version || 'v1') + ' · ' + (data.date || '');
      const cardTotal = (data.frames || []).reduce((s,f) => s + (f.lanes||[]).reduce((ss,l) => ss + (l.cards||[]).length, 0), 0);
      const laneTotal = (data.frames || []).reduce((s,f) => s + (f.lanes||[]).length, 0);
      const miniTotal = (data.frames || []).reduce((s,f) => s + (f.minis||[]).length, 0);
      document.getElementById('tbCount').textContent =
        (data.frames || []).length + ' frames · ' + laneTotal + ' lanes · ' + cardTotal + ' nodes · ' + miniTotal + ' sub-blueprints';
      document.title = data.name + ' — Blueprint';

      // Canvas content
      const canvas = document.getElementById('canvas');
      canvas.appendChild(renderHero(data));
      if (data.phases) canvas.appendChild(renderPhases(data.phases));
      canvas.appendChild(renderAccents(data.accents));
      (data.frames || []).forEach((f, i) => canvas.appendChild(renderFrame(f, i)));
      if (data.edges) canvas.appendChild(renderEdges(data.edges));

      renderMinimap(data.frames || []);
    })
    .catch(err => {
      showError('Blueprint not found', 'No data for "' + biz + '". (' + err.message + ')');
    });

  // ===== Pan + Zoom =====
  const v = document.getElementById('viewport');
  const wrap = document.getElementById('canvasWrap');
  const mmVp = document.getElementById('mmVp');
  const mmCanvas = document.getElementById('mmCanvas');
  const zLevel = document.getElementById('zLevel');
  const CW = 5400, CH = 3800;
  let zoom = 1;

  function applyZoom(){
    wrap.style.transform = 'scale(' + zoom + ')';
    wrap.style.width = (CW * zoom) + 'px';
    wrap.style.height = (CH * zoom) + 'px';
    zLevel.textContent = Math.round(zoom * 100) + '%';
    updateMinimap();
  }
  function updateMinimap(){
    const mmW = mmCanvas.offsetWidth, mmH = mmCanvas.offsetHeight;
    const vw = v.clientWidth, vh = v.clientHeight;
    const sw = CW * zoom, sh = CH * zoom;
    mmVp.style.left = ((v.scrollLeft / sw) * mmW) + 'px';
    mmVp.style.top  = ((v.scrollTop  / sh) * mmH) + 'px';
    mmVp.style.width = Math.min(mmW, (vw / sw) * mmW) + 'px';
    mmVp.style.height = Math.min(mmH, (vh / sh) * mmH) + 'px';
  }
  applyZoom();

  let dragging = false, sX = 0, sY = 0, scX = 0, scY = 0;
  v.addEventListener('mousedown', e => {
    if (e.target.closest('.c, .tb-btn, a, .stat, .zoom button, .minimap')) return;
    dragging = true; sX = e.clientX; sY = e.clientY; scX = v.scrollLeft; scY = v.scrollTop;
  });
  v.addEventListener('mousemove', e => {
    if (!dragging) return;
    v.scrollLeft = scX - (e.clientX - sX);
    v.scrollTop  = scY - (e.clientY - sY);
  });
  ['mouseup','mouseleave'].forEach(ev => v.addEventListener(ev, () => { dragging = false; }));
  v.addEventListener('scroll', updateMinimap);

  document.getElementById('zIn').addEventListener('click', () => { zoom = Math.min(2, zoom + 0.1); applyZoom(); });
  document.getElementById('zOut').addEventListener('click', () => { zoom = Math.max(0.3, zoom - 0.1); applyZoom(); });
  document.getElementById('zReset').addEventListener('click', () => { zoom = 1; applyZoom(); });
  document.getElementById('zFit').addEventListener('click', () => {
    zoom = Math.max(0.3, Math.min(1, v.clientWidth / CW)); applyZoom();
  });
  mmCanvas.addEventListener('click', e => {
    const rect = mmCanvas.getBoundingClientRect();
    const x = (e.clientX - rect.left) / rect.width;
    const y = (e.clientY - rect.top) / rect.height;
    const sw = CW * zoom, sh = CH * zoom;
    v.scrollTo({left: x * sw - v.clientWidth/2, top: y * sh - v.clientHeight/2, behavior: 'smooth'});
  });
  setTimeout(updateMinimap, 200);
})();
</script>
</body>
</html>
